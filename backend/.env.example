# URL Server WAHA Anda dari SumoPod (jangan lupa hapus tanda / di akhir)
WAHA_API_URL=http://your-waha-sumopod-url.com

# API Key / Token WAHA Anda (Jika diatur di SumoPod)
WAHA_API_KEY=YOUR_WAHA_API_KEY

# URL Webhook n8n Anda untuk menerima pesan (Fase 4)
N8N_WEBHOOK_URL=http://your-n8n-sumopod-url.com/webhook/haloflow-wa-incoming

# Port Backend Server
PORT=3000
